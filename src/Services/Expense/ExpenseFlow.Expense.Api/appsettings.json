{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Secret stored in Azure Key Vault"
  },
  "ServiceBus": {
    "FullyQualifiedNamespace": "expenseflow-sb.servicebus.windows.net",
    "TopicName": "expenseflow-integration-events",
    "SubscriptionName": "",
    "Retry": {
      "MaxRetries": 3,
      "DelaySeconds": 2.0,
      "MaxDelaySeconds": 10.0,
      "Mode": "Exponential"
    }
  },
  "JwtSettings": {
    "Secret": "Secret stored in Azure Key Vault",
    "Issuer": "ExpenseFlow",
    "Audience": "ExpenseFlow.Users"
  },
  "BlobStorage": {
    "FullyQualifiedNamespace": "https://expenseflowstore.blob.core.windows.net/",
    "ConnectionString": "",
    "ContainerName": "receipts"
  },
  "AzureKeyVault": {
    "VaultUri": "https://expenseflow-kv.vault.azure.net/"
  },
  "AllowedHosts": "*"
}
