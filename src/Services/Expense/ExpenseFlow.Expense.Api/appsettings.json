{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=ExpenseFlowExpense;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "ServiceBus": {
    "ConnectionString": "Endpoint=sb://example.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=placeholder",
    "TopicName": "expenseflow-integration-events",
    "SubscriptionName": "",
    "Retry": {
      "MaxRetries": 3,
      "DelaySeconds": 2.0,
      "MaxDelaySeconds": 10.0,
      "Mode": "Exponential"
    }
  },
  "JwtSettings": {
    "Secret": "SuperSecretKeyForExpenseFlow",
    "Issuer": "ExpenseFlow",
    "Audience": "ExpenseFlow.Users"
  },
  "AllowedHosts": "*"
}
